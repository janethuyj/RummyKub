# Two ways in:
#
#   1. Internally, by IP:      http://10.1.1.16   (plain HTTP — see note)
#   2. Externally, by name:    https://rummykub.helleon.com  (auto HTTPS)
#
# Both reverse-proxy to the app container on the compose network. WebSocket
# upgrades (SignalR) pass through automatically.
#
# Why the IP is HTTP-only: Let's Encrypt will not issue a certificate for a bare
# IP address (let alone a private 10.x one), so there is no public cert to serve
# there. Browsers on the LAN load the page over http:// and SignalR runs over
# ws:// on the same origin — which works fine. If you want HTTPS on the LAN too,
# see the `tls internal` note at the bottom.

# --- Internal access by IP (LAN) ---
http://10.1.1.16 {
	reverse_proxy app:8080
}

# --- External access by hostname ---
# Requires: an A record  rummykub.helleon.com -> <your public IP>, and your
# router forwarding public ports 80 AND 443 to this host's 80/443. Caddy needs
# them to complete the Let's Encrypt challenge (HTTP-01 on 80, TLS-ALPN-01 on
# 443) and to serve traffic. Forwarding a non-standard external port will break
# certificate issuance.
rummykub.helleon.com {
	reverse_proxy app:8080
}

# --- Co-hosted apps (same compose stack) ---
# MahjongHu joins this stack as the `majiang` service via
# deploy/docker-compose.majiang.yml (shipped by the MahjongHu repo's deploy
# script), and the GameCenter static page is mounted into this container at
# /srv/gamecenter by that same overlay. This file is the source of truth for
# ALL domains on the VM — deploy scripts overwrite the VM's copy.
majiang.helleon.com {
	reverse_proxy majiang:8080
}

games.helleon.com {
	root * /srv/gamecenter
	file_server
}

# --- Optional: HTTPS on the LAN too ---
# Replace the `http://10.1.1.16` block above with the version below to have Caddy
# serve its own internally-signed cert. Browsers will warn until you install
# Caddy's root CA (it prints the path in the logs) on each client machine.
#
#   10.1.1.16 {
#   	tls internal
#   	reverse_proxy app:8080
#   }
